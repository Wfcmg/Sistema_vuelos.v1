@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  * { box-sizing: border-box; }
  body { @apply text-white bg-[#050816]; }
}


/* DARK PREMIUM KILLER - William */
html, body {
  background:
    radial-gradient(circle at 20% 0%, rgba(245, 158, 11, 0.12), transparent 30%),
    radial-gradient(circle at 80% 20%, rgba(217, 119, 6, 0.10), transparent 28%),
    #050816 !important;
  color: #E5E7EB;
}

body {
  min-height: 100vh;
}

::selection {
  background: rgba(245, 158, 11, 0.35);
  color: #fff;
}

input, select, textarea {
  color-scheme: dark;
}

* {
  scrollbar-width: thin;
  scrollbar-color: rgba(245, 158, 11, 0.45) rgba(15, 23, 42, 0.9);
}

::-webkit-scrollbar {
  width: 10px;
}

::-webkit-scrollbar-track {
  background: #050816;
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(180deg, #f59e0b, #92400e);
  border-radius: 999px;
}

